{
  "name": "static-dom",
  "version": "0.1.0",
  "description": "Facade for @static-dom/core: re-exports the SDOM library under the unscoped name",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./optics": "./src/optics.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-dev-runtime.ts",
    "./hyperscript": "./src/hyperscript.ts",
    "./htm": "./src/htm.ts",
    "./html": "./src/html.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./optics": {
        "types": "./dist/optics.d.ts",
        "import": "./dist/optics.js"
      },
      "./jsx-runtime": {
        "types": "./dist/jsx-runtime.d.ts",
        "import": "./dist/jsx-runtime.js"
      },
      "./jsx-dev-runtime": {
        "types": "./dist/jsx-dev-runtime.d.ts",
        "import": "./dist/jsx-dev-runtime.js"
      },
      "./hyperscript": {
        "types": "./dist/hyperscript.d.ts",
        "import": "./dist/hyperscript.js"
      },
      "./htm": {
        "types": "./dist/htm.d.ts",
        "import": "./dist/htm.js"
      },
      "./html": {
        "types": "./dist/html.d.ts",
        "import": "./dist/html.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@static-dom/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
  },
  "license": "(Apache-2.0 OR MIT)"
}
