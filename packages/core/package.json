{
  "name": "@static-dom/core",
  "version": "0.1.0",
  "description": "Static DOM: a virtual-DOM-free UI library with precise TypeScript types",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./optics": "./src/optics.ts",
    "./internal": "./src/internal.ts",
    "./jsx-runtime": "./src/jsx-runtime.ts",
    "./jsx-dev-runtime": "./src/jsx-dev-runtime.ts",
    "./hyperscript": "./src/hyperscript.ts",
    "./htm": "./src/htm.ts",
    "./html": "./src/html.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./optics": {
        "types": "./dist/optics.d.ts",
        "import": "./dist/optics.js"
      },
      "./internal": {
        "types": "./dist/internal.d.ts",
        "import": "./dist/internal.js"
      },
      "./jsx-runtime": {
        "types": "./dist/jsx-runtime.d.ts",
        "import": "./dist/jsx-runtime.js"
      },
      "./jsx-dev-runtime": {
        "types": "./dist/jsx-dev-runtime.d.ts",
        "import": "./dist/jsx-dev-runtime.js"
      },
      "./hyperscript": {
        "types": "./dist/hyperscript.d.ts",
        "import": "./dist/hyperscript.js"
      },
      "./htm": {
        "types": "./dist/htm.d.ts",
        "import": "./dist/htm.js"
      },
      "./html": {
        "types": "./dist/html.d.ts",
        "import": "./dist/html.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "LICENSE-APACHE",
    "LICENSE-MIT",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "dev": "vite examples"
  },
  "keywords": [
    "static-dom",
    "sdom",
    "ui",
    "dom",
    "no-vdom",
    "virtual-dom",
    "elm-architecture",
    "typescript",
    "lens",
    "optics",
    "incremental",
    "reactive"
  ],
  "author": "Josh Burgess",
  "license": "(Apache-2.0 OR MIT)",
  "homepage": "https://github.com/joshburgess/static-dom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshburgess/static-dom.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/joshburgess/static-dom/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/browser": "^3.2.4",
    "happy-dom": "^20.8.9",
    "inferno": "^9.1.0",
    "inferno-create-element": "^9.1.0",
    "playwright": "^1.59.1",
    "preact": "^10.29.1",
    "solid-js": "^1.9.12",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
