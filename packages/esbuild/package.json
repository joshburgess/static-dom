{
  "name": "@static-dom/esbuild",
  "version": "0.1.0",
  "description": "esbuild plugin and config helpers for SDOM JSX",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "LICENSE-APACHE",
    "LICENSE-MIT",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "static-dom",
    "sdom",
    "esbuild",
    "esbuild-plugin",
    "jsx",
    "jsx-runtime"
  ],
  "author": "Josh Burgess",
  "license": "(Apache-2.0 OR MIT)",
  "homepage": "https://github.com/joshburgess/static-dom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshburgess/static-dom.git",
    "directory": "packages/esbuild"
  },
  "bugs": {
    "url": "https://github.com/joshburgess/static-dom/issues"
  },
  "peerDependencies": {
    "esbuild": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
