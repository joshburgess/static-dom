{
  "name": "@static-dom/react",
  "version": "0.1.0",
  "description": "React adapter for static-dom: drop SDOM subtrees into existing React apps",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "LICENSE-APACHE",
    "LICENSE-MIT",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "static-dom",
    "sdom",
    "react",
    "react-adapter",
    "ui",
    "dom"
  ],
  "author": "Josh Burgess",
  "license": "(Apache-2.0 OR MIT)",
  "homepage": "https://github.com/joshburgess/static-dom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshburgess/static-dom.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/joshburgess/static-dom/issues"
  },
  "dependencies": {
    "@static-dom/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.8.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
