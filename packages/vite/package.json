{
  "name": "@static-dom/vite",
  "version": "0.1.0",
  "description": "Vite plugin that configures the SDOM JSX runtime",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "LICENSE-APACHE",
    "LICENSE-MIT",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "static-dom",
    "sdom",
    "vite",
    "vite-plugin",
    "jsx",
    "jsx-runtime"
  ],
  "author": "Josh Burgess",
  "license": "(Apache-2.0 OR MIT)",
  "homepage": "https://github.com/joshburgess/static-dom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshburgess/static-dom.git",
    "directory": "packages/vite"
  },
  "bugs": {
    "url": "https://github.com/joshburgess/static-dom/issues"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@static-dom/core": "workspace:*",
    "@types/node": "^20.0.0",
    "happy-dom": "^20.8.9",
    "vitest": "^3.2.4"
  }
}
