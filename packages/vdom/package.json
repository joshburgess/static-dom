{
  "name": "@static-dom/vdom",
  "version": "0.1.0",
  "description": "Tachys-backed virtual DOM boundary for static-dom",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE-APACHE",
    "LICENSE-MIT",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "static-dom",
    "sdom",
    "vdom",
    "virtual-dom",
    "tachys",
    "ui",
    "dom"
  ],
  "author": "Josh Burgess",
  "license": "(Apache-2.0 OR MIT)",
  "homepage": "https://github.com/joshburgess/static-dom#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshburgess/static-dom.git",
    "directory": "packages/vdom"
  },
  "bugs": {
    "url": "https://github.com/joshburgess/static-dom/issues"
  },
  "dependencies": {
    "@static-dom/core": "workspace:*"
  },
  "peerDependencies": {
    "tachys": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "happy-dom": "^20.8.9",
    "tachys": "^0.1.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
