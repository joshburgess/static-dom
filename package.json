{
  "name": "@sdom/core",
  "version": "0.1.0",
  "description": "Static DOM — a virtual-DOM-free UI library with precise TypeScript types",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./optics": {
      "types": "./dist/optics.d.ts",
      "import": "./dist/optics.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.8.9",
    "preact": "^10.29.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "solid-js": "^1.9.12",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "license": "MIT"
}
